@pytest.mark.vuln_id("DNS_CACHE_SNOOP")
def test_dns_cache_snoop():
    ip = "{{ ip }}"
    port = 53

    # Send non-recursive query for common domains to check cache
    common_domains = ["google.com", "facebook.com", "amazon.com"]
    for domain in common_domains:
        try:
            # Build non-recursive query (RD=0)
            query = _build_dns_query(domain, qtype=1)
            # Clear RD bit: byte 2 bit 0
            query_list = bytearray(query)
            query_list[2] = query_list[2] & 0xFE  # Clear RD bit
            query = bytes(query_list)

            sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            sock.settimeout(TIMEOUT)
            sock.sendto(query, (ip, port))
            response, _ = sock.recvfrom(1024)
            sock.close()

            if len(response) > 12:
                ancount = struct.unpack("!H", response[6:8])[0]
                if ancount > 0:
                    assert True  # Cached response found
                    return
        except Exception:
            continue

    pytest.fail("DNS cache snooping not possible")


def _build_dns_query(domain, qtype=1, qclass=1):
    """Build a minimal DNS query packet."""
    import random
    tid = random.randint(0, 65535)
    header = struct.pack("!HHHHHH", tid, 0x0100, 1, 0, 0, 0)

    qname = b""
    for label in domain.split("."):
        qname += bytes([len(label)]) + label.encode()
    qname += b"\x00"

    question = qname + struct.pack("!HH", qtype, qclass)
    return header + question
