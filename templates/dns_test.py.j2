"""Auto-generated DNS vulnerability tests for {{ ip }}"""
import pytest
import socket
import struct

TIMEOUT = 5

@pytest.mark.vuln_id("DNS_OPEN_RESOLVER")
def test_dns_open_resolver():
    ip = "{{ ip }}"
    port = 53

    try:
        # Build DNS query for google.com (type A)
        query = _build_dns_query("google.com", qtype=1)
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.settimeout(TIMEOUT)
        sock.sendto(query, (ip, port))
        response, _ = sock.recvfrom(1024)
        sock.close()

        # Check if we got a valid DNS response
        if len(response) > 12:
            flags = struct.unpack("!H", response[2:4])[0]
            rcode = flags & 0x0F
            if rcode == 0:  # No error
                assert True  # Open resolver
                return
    except Exception:
        pass

    pytest.fail("DNS server is not an open resolver")


@pytest.mark.vuln_id("DNS_INTERNAL_DISCLOSURE")
def test_dns_internal_disclosure():
    ip = "{{ ip }}"
    port = 53

    try:
        # Attempt zone transfer (AXFR)
        query = _build_dns_query("localhost", qtype=252)  # AXFR
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(TIMEOUT)
        sock.connect((ip, port))
        # TCP DNS requires length prefix
        sock.send(struct.pack("!H", len(query)) + query)
        response = sock.recv(4096)
        sock.close()

        if len(response) > 14:
            assert True  # Zone transfer possible
            return
    except Exception:
        pass

    pytest.fail("DNS zone transfer not possible")


