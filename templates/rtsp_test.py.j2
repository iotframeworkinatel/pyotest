@pytest.mark.vuln_id("RTSP_DEFAULT_CREDS")
def test_rtsp_default_creds():
    ip = "{{ ip }}"
    port = 554
    import base64

    credentials = [("admin", "admin"), ("admin", "12345"), ("root", "root")]

    for user, passwd in credentials:
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(TIMEOUT)
            sock.connect((ip, port))

            auth = base64.b64encode(f"{user}:{passwd}".encode()).decode()
            request = (
                f"DESCRIBE rtsp://{ip}:{port}/ RTSP/1.0\r\n"
                f"CSeq: 1\r\n"
                f"Authorization: Basic {auth}\r\n"
                f"\r\n"
            )
            sock.send(request.encode())
            response = sock.recv(4096).decode(errors="ignore")
            sock.close()

            if "200 OK" in response:
                assert True  # Default credentials accepted
                return
        except Exception:
            continue

    pytest.fail("RTSP default credentials not accepted")


